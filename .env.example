DB_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=Host=localhost;Port=5432;Database=fasolt;Username=fasolt;Password=fasolt_dev
# iOS app bundle ID and Apple Developer Team ID — used for APNs push,
# /.well-known/apple-app-site-association (iCloud Keychain autofill across
# the iOS app and the OAuth web view), Sign in with Apple audience validation,
# and the /api/health appleLogin feature flag.
APPLE_BUNDLE_ID=com.fasolt.app
APPLE_TEAM_ID=
APNS_KEY_ID=
APNS_KEY_BASE64=
APNS_USE_SANDBOX=true
PLUNK_API_KEY=
PLUNK_FROM_EMAIL=noreply@fasolt.app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OPENIDDICT_ENCRYPTION_CERT_PATH=
OPENIDDICT_SIGNING_CERT_PATH=
ADMIN_EMAIL=
# Error tracking (Bugsink) — optional, leave empty to disable
BUGSINK_DSN=
VITE_BUGSINK_DSN=
# OTP pepper for email verification codes (HMAC-SHA256 key)
# Generate with: openssl rand -hex 32
OTP_PEPPER=
