@{
    var pageTitle = ViewData["Title"] as string ?? "fasolt";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@pageTitle — fasolt</title>
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
</head>
<body>
    <div class="oauth-shell">
        <div class="relative w-full max-w-sm">
            <div class="oauth-brand">
                <svg class="oauth-mark" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="5" width="16" height="11" rx="2" />
                    <rect x="6" y="8" width="16" height="11" rx="2" fill="var(--paper-0)" />
                    <line x1="9" y1="13" x2="16" y2="13" stroke="var(--accent)" stroke-width="2" />
                </svg>
                <span>fasolt</span>
            </div>
            @RenderBody()
        </div>
    </div>
</body>
</html>
